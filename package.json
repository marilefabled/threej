{
  "name": "threej",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev":            "vite",
    "build":          "vite build",
    "build:lib":      "vite build --config vite.lib.config.ts",
    "preview":        "vite preview",
    "typecheck":      "tsc --noEmit",

    "dev:electron":   "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "npm run build && electron-builder",

    "build:mobile":   "npm run build && npx cap sync",
    "open:ios":       "npx cap open ios",
    "open:android":   "npx cap open android",

    "unpack":         "node tools/unpack-unitypackage.mjs",
    "vendor:manifest":"node tools/build-vendor-manifest.mjs"
  },
  "dependencies": {
    "@capacitor/cli":              "^8.4.1",
    "@capacitor/core":             "^8.4.1",
    "@dimforge/rapier3d-compat":   "^0.14.0",
    "gsap":                        "^3.12.5",
    "howler":                      "^2.2.4",
    "inkjs":                       "^2.4.0",
    "lil-gui":                     "^0.20.0",
    "miniplex":                    "^2.0.0",
    "three":                       "0.165.0"
  },
  "devDependencies": {
    "@types/howler":       "^2.2.11",
    "@types/node":         "^26.0.0",
    "@types/three":        "^0.165.0",
    "concurrently":        "^10.0.3",
    "cross-env":           "^10.1.0",
    "electron":            "^42.4.1",
    "electron-builder":    "^26.15.3",
    "typescript":          "^5.5.0",
    "vite":                "^5.4.0",
    "vite-plugin-pwa":     "^1.3.0",
    "wait-on":             "^9.0.10"
  },
  "build": {
    "appId":       "dev.threej.engine",
    "productName": "ThreeJ",
    "directories": { "output": "dist-electron" },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        { "target": "dmg",  "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Game"
    }
  }
}
